// Codespace / dev container for Gitarium. Opening this repo in a GitHub
// Codespace builds the toolchain, builds the browser wasm once, then
// auto-starts the demo server in proxy mode so every GitHub API call is
// routed through the codespace. The auto-serve is Codespace-only — local
// VS Code (with or without a devcontainer) stays silent. See auto-serve.sh.
{
  "name": "Gitarium",
  "build": { "dockerfile": "Dockerfile" },

  // The demo server (scripts/serve.ts) listens here. Codespaces forwards the
  // port and opens it in a browser tab automatically.
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "Gitarium", "onAutoForward": "openBrowser" }
  },

  // Declare the secrets the app reads. Set them under Codespace secrets
  // (https://github.com/settings/codespaces) — Codespaces prompts for them on
  // first create. NOTE: GitHub auth in proxy mode uses only the PAT pasted at
  // the auth screen — GITHUB_TOKEN is intentionally NOT read (the codespace's
  // auto-injected token is ignored), so it is not declared here.
  "secrets": {
    "ANTHROPIC_API_KEY": "Anthropic API key for the in-app and headless agent."
  },
  // Forward the injected secret into terminals / tasks / the server process.
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${containerEnv:ANTHROPIC_API_KEY}"
  },

  // Build the browser wasm once on create so the app is ready to serve
  // immediately. (First create compiles all deps — a few minutes; cached after.)
  "postCreateCommand": "wasm-pack build --target web",

  // The proxy server auto-starts in a dedicated FOREGROUND terminal via the
  // `auto-serve-codespace` task (runOptions.runOn: folderOpen) in
  // .vscode/tasks.json — Codespace-only (auto-serve.sh guards on $CODESPACES).
  // A task-owned terminal process isn't reaped the way a backgrounded lifecycle
  // child can be, so there is no postStartCommand here.
  "customizations": {
    "vscode": {
      "extensions": ["rust-lang.rust-analyzer", "oven.bun-vscode"]
    }
  }
}
