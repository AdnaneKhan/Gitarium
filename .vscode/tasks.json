{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-web",
      "type": "shell",
      "command": "wasm-pack build --target web",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "build-headless",
      "type": "shell",
      "command": "wasm-pack build crates/headless --target web",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "build-single-file",
      "type": "shell",
      "command": "bun scripts/build-html.ts",
      "problemMatcher": []
    },
    {
      // Auto-start the proxy server in a dedicated FOREGROUND terminal whenever
      // the workspace opens. Codespace-only — auto-serve.sh no-ops unless
      // $CODESPACES=true. Living in a real integrated terminal (not a
      // backgrounded lifecycle child) is what keeps it from being reaped.
      "label": "auto-serve-codespace",
      "type": "shell",
      "command": "bash .devcontainer/auto-serve.sh",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "runOptions": { "runOn": "folderOpen", "instanceLimit": 1 }
    },
    {
      // Interactive foreground serve (proxy mode). Run on demand; if the
      // auto-serve terminal is already running, stop it (Ctrl+C / trash the
      // terminal) first to free port 8080.
      "label": "serve-proxy",
      "type": "shell",
      "command": "bun scripts/serve.ts --api-proxy",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      // Same server, no proxy: the browser calls api.github.com directly.
      "label": "serve-direct",
      "type": "shell",
      "command": "bun scripts/serve.ts",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
